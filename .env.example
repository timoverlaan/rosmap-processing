# Example environment variables for ROSMAP processing
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Synapse authentication token
# Get your token from: https://www.synapse.org/#!PersonalAccessTokens:
SYNAPSE_AUTH_TOKEN=your_synapse_token_here

# AWS credentials (if needed for SeaAD data)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Optional: Custom paths
# ROSMAP_DATA_DIR=/path/to/data
# ROSMAP_OUTPUT_DIR=/path/to/output
